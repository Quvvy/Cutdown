{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cutdown",
  "version": "0.2.3",
  "identifier": "app.cutdown.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cutdown",
        "width": 1160,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; connect-src ipc: http://ipc.localhost http://127.0.0.1:7794",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*.mp4",
          "**/*.mkv",
          "**/*.mov",
          "**/*.webm",
          "**/*.ts",
          "**/*.avi",
          "**/*.flv"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["mp4", "mkv", "mov", "webm", "ts", "avi", "flv"],
        "description": "Video file",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  }
}
