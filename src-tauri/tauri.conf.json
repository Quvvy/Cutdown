{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cutdown",
  "version": "0.1.0",
  "identifier": "app.cutdown.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cutdown",
        "width": 1160,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": ["../public/ffmpeg/*"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
